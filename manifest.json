{
    "manifest_version": 3,
    "name": "Crunchy Skip",
    "version": "1.1",
    "description": "Recap, intro and credits auto-skip on Crunchyroll",

    "permissions": ["storage"],

    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },

    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png"
        }
    },

    "content_scripts":[
        {
            "matches": ["https://www.crunchyroll.com/*"],
            "js": ["content.js"]
        }
    ]
}