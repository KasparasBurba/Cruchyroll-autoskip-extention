{
    "manifest_version": 3,
    "name": "My extention",
    "version": "0.0.1",
    "permissions": [
        "storage"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts":[
        {
            "matches": ["https://www.crunchyroll.com/*"],
            "js": ["content.js"]
        }
    ]
}